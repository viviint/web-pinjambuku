APP_NAME="User Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_PORT=8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=users_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# JWT issuer for other services.
JWT_ALGO=RS256
# Leave these unset to use config/jwt.php defaults based on Laravel storage_path().
# In Docker, docker-compose.yml sets absolute file:// paths.
# JWT_PUBLIC_KEY=file:///absolute/path/to/storage/keys/jwt_public.pem
# JWT_PRIVATE_KEY=file:///absolute/path/to/storage/keys/jwt_private.pem
JWT_PASSPHRASE=

# Service-to-service calls.
PEMINJAMAN_SERVICE_URL=http://localhost:8003
SERVICE_KEY=change-me-shared-service-key
